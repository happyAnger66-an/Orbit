# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# setuptools / distutils build outputs only — do NOT use bare ``lib/`` (would ignore e.g. ``frontend/desktop/lib/``)
build/lib/
build/lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Testing
.pytest_cache/
.coverage
htmlcov/

# MyPy
.mypy_cache/

# Root-level JSON artifacts (do not commit top-level *.json)
/*.json

# Session store backups (tests/dev runs)
/orbit.sessions.json.bak*

# Desktop app (Next + Tauri) — build / dev / bundle artifacts under frontend/desktop/
frontend/desktop/node_modules/
frontend/desktop/.next/
frontend/desktop/out/
frontend/desktop/.turbo/
frontend/desktop/.vercel/
frontend/desktop/coverage/
frontend/desktop/.eslintcache
frontend/desktop/*.tsbuildinfo
frontend/desktop/npm-debug.log*
frontend/desktop/yarn-debug.log*
frontend/desktop/yarn-error.log*
frontend/desktop/pnpm-debug.log*
frontend/desktop/.env
frontend/desktop/.env.*
!frontend/desktop/.env*.example
frontend/desktop/src-tauri/target/
frontend/desktop/src-tauri/gen/
